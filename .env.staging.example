# =====================================================================
#  Connex staging env — copy to `.env.staging` on the server and fill in.
#  This file is loaded by docker-compose.prod.yml AND passed into the
#  Laravel app + queue + scheduler containers.
# =====================================================================

# --- Public identity ---
APP_NAME=Connex
APP_ENV=staging
APP_KEY=                                  # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://dev.connex-build.co.il
APP_DOMAIN=dev.connex-build.co.il         # used by Caddy

APP_LOCALE=he
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=he_IL

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Database (docker service name) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=connex
DB_USERNAME=connex
DB_PASSWORD=replace-me-strong-password

# --- Redis (docker service name) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.connex-build.co.il
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Filesystem (local, not S3, for staging) ---
FILESYSTEM_DISK=public

# --- Mail (log driver for staging — no real mail) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@connex-build.co.il"
MAIL_FROM_NAME="${APP_NAME}"

# --- CORS / Sanctum ---
FRONTEND_URL=https://dev.connex-build.co.il
CORS_ALLOWED_ORIGINS=https://dev.connex-build.co.il
SANCTUM_STATEFUL_DOMAINS=dev.connex-build.co.il

# --- Trust proxy (Caddy terminates TLS) ---
TRUSTED_PROXIES=*

# --- Staging admin seeded by StagingSeeder ---
STAGING_ADMIN_EMAIL=admin@connex-build.co.il
STAGING_ADMIN_PASSWORD=ChangeMe!2026
